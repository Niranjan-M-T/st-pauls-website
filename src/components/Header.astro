---
const services = [
  { href: '/services/coffin-box', label: 'Coffin Boxes' },
  { href: '/services/freezer-box', label: 'Freezer Box on Rent' },
  { href: '/services/hearse-van', label: 'Hearse Van' },
  { href: '/services/embalming', label: 'Embalming & Dressing' },
  { href: '/services/repatriation', label: 'International Repatriation' },
];
---

<header class="site-header">
  <div class="header-shell">
    <div class="header-pill" id="header-pill">
      <a href="/" class="brand" aria-label="St. Paul's Funeral Undertakers — Home">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round">
            <path d="M12 4v16M7 9h10" />
          </svg>
        </span>
        <span class="brand-text">
          <span class="brand-name">St.&nbsp;Paul&rsquo;s</span>
          <span class="brand-sub">Funeral Undertakers</span>
        </span>
      </a>

      <nav class="nav-desktop" aria-label="Primary">
        <a href="/" class="nav-link">Home</a>
        <a href="/ambulance-service" class="nav-link">Ambulance</a>
        <div class="dropdown">
          <button class="nav-link dropdown-toggle" aria-haspopup="true" aria-expanded="false">
            Services
            <svg class="caret" viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"><path d="M3 4.5 6 7.5 9 4.5"/></svg>
          </button>
          <div class="dropdown-menu">
            {services.map(s => <a href={s.href}>{s.label}</a>)}
          </div>
        </div>
        <a href="/contact" class="nav-link">Contact</a>
      </nav>

      <div class="header-actions">
        <a href="tel:+917760911567" class="btn btn--gold header-cta">
          <span class="cta-label"><span class="cta-247">24/7</span> 77609&nbsp;11567</span>
          <span class="btn-ico">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
          </span>
        </a>

        <button class="menu-toggle" id="menu-toggle" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
          <span class="menu-line"></span>
          <span class="menu-line"></span>
        </button>
      </div>
    </div>
  </div>
</header>

<!-- Mobile overlay menu -->
<div class="mobile-menu" id="mobile-menu" aria-hidden="true">
  <div class="mobile-menu-inner">
    <nav class="mobile-nav" aria-label="Mobile">
      <a href="/" class="m-link" style="--i: 0">Home</a>
      <a href="/ambulance-service" class="m-link" style="--i: 1">Ambulance Service</a>
      <a href="/contact" class="m-link" style="--i: 2">Contact</a>
      <div class="m-divider" style="--i: 3"><span>Our services</span></div>
      {services.map((s, i) => (
        <a href={s.href} class="m-link m-link--small" style={`--i: ${i + 4}`}>{s.label}</a>
      ))}
    </nav>
    <div class="mobile-foot" style="--i: 10">
      <p class="mobile-foot-note">Available day and night, every day</p>
      <a href="tel:+917760911567" class="mobile-tel">77609 11567</a>
      <a href="tel:+917996794943" class="mobile-tel">79967 94943</a>
    </div>
  </div>
</div>

<style>
  .site-header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 90;
    padding-top: clamp(0.8rem, 2vw, 1.2rem);
    pointer-events: none;
  }

  .header-shell {
    max-width: calc(var(--max-width) + 1rem);
    margin: 0 auto;
    padding: 0 clamp(0.9rem, 3vw, 2rem);
  }

  .header-pill {
    pointer-events: auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1.5rem;
    padding: 0.55rem 0.55rem 0.55rem 1.15rem;
    border-radius: 999px;
    background: rgba(251, 250, 247, 0.72);
    backdrop-filter: blur(18px) saturate(1.4);
    -webkit-backdrop-filter: blur(18px) saturate(1.4);
    border: 1px solid rgba(16, 27, 49, 0.08);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.7) inset, 0 14px 34px -18px rgba(16, 27, 49, 0.35);
    transition: box-shadow 500ms var(--ease), background 500ms var(--ease);
  }

  .header-pill.is-scrolled {
    background: rgba(251, 250, 247, 0.88);
    box-shadow: 0 1px 0 rgba(255, 255, 255, 0.7) inset, 0 22px 44px -20px rgba(16, 27, 49, 0.45);
  }

  /* Brand */
  .brand {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    flex: none;
  }

  .brand-mark {
    width: 2.4rem;
    height: 2.4rem;
    border-radius: 999px;
    background: var(--ink);
    color: var(--gold-2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 8px 18px -8px rgba(16, 27, 49, 0.6);
  }

  .brand-mark svg { width: 1.05rem; height: 1.05rem; }

  .brand-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .brand-name {
    font-family: var(--font-display);
    font-size: 1.28rem;
    font-weight: 700;
    color: var(--ink);
    letter-spacing: 0.01em;
  }

  .brand-sub {
    font-size: 0.6rem;
    font-weight: 600;
    letter-spacing: 0.24em;
    text-transform: uppercase;
    color: var(--muted);
  }

  /* Desktop nav */
  .nav-desktop {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .nav-link {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.55rem 0.95rem;
    border-radius: 999px;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--text);
    background: transparent;
    border: none;
    cursor: pointer;
    font-family: var(--font-body);
    transition: background 350ms var(--ease), color 350ms var(--ease);
  }

  .nav-link:hover {
    background: rgba(16, 27, 49, 0.06);
    color: var(--ink);
  }

  .caret {
    width: 0.7rem;
    height: 0.7rem;
    transition: transform 350ms var(--ease);
  }

  .dropdown:hover .caret,
  .dropdown:focus-within .caret { transform: rotate(180deg); }

  /* Dropdown */
  .dropdown { position: relative; }

  .dropdown-menu {
    position: absolute;
    top: calc(100% + 0.85rem);
    left: 50%;
    min-width: 250px;
    padding: 0.5rem;
    border-radius: 1.35rem;
    background: rgba(251, 250, 247, 0.92);
    backdrop-filter: blur(20px) saturate(1.4);
    -webkit-backdrop-filter: blur(20px) saturate(1.4);
    border: 1px solid rgba(16, 27, 49, 0.08);
    box-shadow: 0 1px 0 rgba(255,255,255,0.8) inset, 0 30px 60px -24px rgba(16, 27, 49, 0.4);
    opacity: 0;
    transform: translateX(-50%) translateY(10px) scale(0.96);
    transform-origin: top center;
    pointer-events: none;
    transition: opacity 350ms var(--ease), transform 350ms var(--ease-spring);
  }

  /* Invisible bridge to prevent hover loss between button and menu */
  .dropdown-menu::before {
    content: '';
    position: absolute;
    top: -1.5rem;
    left: 0;
    right: 0;
    height: 1.5rem;
  }

  .dropdown:hover .dropdown-menu,
  .dropdown:focus-within .dropdown-menu {
    opacity: 1;
    transform: translateX(-50%) translateY(0) scale(1);
    pointer-events: auto;
  }

  .dropdown-menu a {
    display: block;
    padding: 0.7rem 1rem;
    border-radius: 0.9rem;
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--text);
    transition: background 250ms var(--ease), color 250ms var(--ease), padding-left 350ms var(--ease-spring);
  }

  .dropdown-menu a:hover {
    background: rgba(16, 27, 49, 0.05);
    color: var(--ink);
    padding-left: 1.25rem;
  }

  /* Actions */
  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex: none;
  }

  .header-cta {
    font-size: 0.88rem;
    padding-left: 1.25rem;
  }

  .cta-247 {
    color: rgba(255, 255, 255, 0.75);
    font-weight: 700;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    margin-right: 0.3rem;
  }

  /* Hamburger */
  .menu-toggle {
    display: none;
    position: relative;
    width: 2.9rem;
    height: 2.9rem;
    border-radius: 999px;
    border: 1px solid rgba(16, 27, 49, 0.1);
    background: var(--ink);
    cursor: pointer;
    flex: none;
  }

  .menu-line {
    position: absolute;
    left: 50%;
    top: 50%;
    width: 1.1rem;
    height: 1.5px;
    border-radius: 2px;
    background: #f5f2ec;
    transition: transform 450ms var(--ease-spring);
  }

  .menu-line:nth-child(1) { transform: translate(-50%, calc(-50% - 3.5px)); }
  .menu-line:nth-child(2) { transform: translate(-50%, calc(-50% + 3.5px)); }

  .menu-toggle.open .menu-line:nth-child(1) { transform: translate(-50%, -50%) rotate(45deg); }
  .menu-toggle.open .menu-line:nth-child(2) { transform: translate(-50%, -50%) rotate(-45deg); }

  /* Mobile overlay */
  .mobile-menu {
    position: fixed;
    inset: 0;
    z-index: 85;
    background: rgba(14, 23, 42, 0.9);
    backdrop-filter: blur(28px) saturate(1.2);
    -webkit-backdrop-filter: blur(28px) saturate(1.2);
    opacity: 0;
    pointer-events: none;
    transition: opacity 500ms var(--ease);
  }

  .mobile-menu.open {
    opacity: 1;
    pointer-events: auto;
  }

  .mobile-menu-inner {
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    padding: 7.5rem clamp(1.8rem, 7vw, 3rem) 3rem;
    overflow-y: auto;
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .m-link,
  .m-divider,
  .mobile-foot {
    opacity: 0;
    transform: translateY(1.4rem);
    transition: opacity 600ms var(--ease), transform 600ms var(--ease-spring);
    transition-delay: 0ms;
  }

  .mobile-menu.open .m-link,
  .mobile-menu.open .m-divider,
  .mobile-menu.open .mobile-foot {
    opacity: 1;
    transform: translateY(0);
    transition-delay: calc(120ms + var(--i) * 45ms);
  }

  .m-link {
    font-family: var(--font-display);
    font-size: clamp(1.9rem, 6.5vw, 2.5rem);
    font-weight: 600;
    color: #f4f1ea;
    line-height: 1.25;
  }

  .m-link:hover { color: var(--gold-2); }

  .m-link--small {
    font-size: clamp(1.25rem, 4.5vw, 1.5rem);
    font-weight: 500;
    color: rgba(244, 241, 234, 0.82);
  }

  .m-divider {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin: 1.4rem 0 0.9rem;
    font-size: 0.64rem;
    font-weight: 600;
    letter-spacing: 0.26em;
    text-transform: uppercase;
    color: var(--gold-2);
  }

  .m-divider::after {
    content: '';
    height: 1px;
    flex: 1;
    background: rgba(244, 241, 234, 0.16);
  }

  .mobile-foot {
    margin-top: 2.5rem;
    padding-top: 1.6rem;
    border-top: 1px solid rgba(244, 241, 234, 0.14);
  }

  .mobile-foot-note {
    font-size: 0.8rem;
    color: rgba(244, 241, 234, 0.55);
    margin-bottom: 0.5rem;
  }

  .mobile-tel {
    display: block;
    font-family: var(--font-display);
    font-size: 1.9rem;
    font-weight: 600;
    color: var(--gold-2);
    line-height: 1.4;
  }

  @media (max-width: 1024px) {
    .nav-desktop { display: none; }
    .menu-toggle { display: block; }
  }

  @media (max-width: 560px) {
    .header-pill {
      gap: 0.75rem;
      padding: 0.4rem 0.4rem 0.4rem 0.9rem;
    }
    .brand-name { font-size: 1.15rem; }
    .header-cta .cta-label { display: none; }
    .header-cta { padding-left: 0.5rem; }
    .brand-sub { letter-spacing: 0.16em; }
  }
</style>

<script>
  const pill = document.getElementById('header-pill');
  const toggle = document.getElementById('menu-toggle');
  const menu = document.getElementById('mobile-menu');

  let scrolled = false;
  const onScroll = () => {
    const now = window.scrollY > 24;
    if (now !== scrolled) {
      scrolled = now;
      pill?.classList.toggle('is-scrolled', now);
    }
  };
  window.addEventListener('scroll', onScroll, { passive: true });
  onScroll();

  toggle?.addEventListener('click', () => {
    const open = !menu?.classList.contains('open');
    menu?.classList.toggle('open', open);
    toggle.classList.toggle('open', open);
    toggle.setAttribute('aria-expanded', String(open));
    menu?.setAttribute('aria-hidden', String(!open));
    document.documentElement.style.overflow = open ? 'hidden' : '';
  });

  // Close menu when a link is chosen
  menu?.querySelectorAll('a').forEach(a => {
    a.addEventListener('click', () => {
      menu.classList.remove('open');
      toggle?.classList.remove('open');
      toggle?.setAttribute('aria-expanded', 'false');
      menu.setAttribute('aria-hidden', 'true');
      document.documentElement.style.overflow = '';
    });
  });
</script>
