---
export interface GalleryItem {
  src: string;
  alt: string;
  label?: string;
  position?: string;
}

export interface Props {
  kicker?: string;
  heading: string;
  emphasis?: string;
  note?: string;
  items: GalleryItem[];
  id: string;
}

const { kicker, heading, emphasis, note, items, id } = Astro.props;
const count = items.length;
---

<section class="section--tight bg-paper2 gallery-block">
  <div class="container">
    <div class="section-header section-header--center reveal">
      {kicker && <span class="eyebrow">{kicker}</span>}
      <h2>{heading} {emphasis && <em class="serif-italic text-gold">{emphasis}</em>}</h2>
      {note && <p>{note}</p>}
    </div>

    <div class={`gallery-grid gallery--n${count}`} data-stagger="70" data-gallery={id}>
      {items.map((item, i) => (
        <button
          class="g-tile reveal"
          type="button"
          data-index={i}
          aria-label={`View larger: ${item.label ?? item.alt}`}
        >
          <img
            src={item.src}
            alt={item.alt}
            loading="lazy"
            style={item.position ? `object-position: ${item.position};` : undefined}
          />
          {item.label && <span class="g-label">{item.label}</span>}
          <span class="g-zoom" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
              <path d="M14 4h6v6M20 4l-7 7M10 20H4v-6M4 20l7-7" />
            </svg>
          </span>
        </button>
      ))}
    </div>
  </div>
</section>

<div class="lightbox" data-lightbox={id} hidden>
  <button class="lb-btn lb-close" type="button" aria-label="Close gallery">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round">
      <path d="M6 6l12 12M18 6L6 18" />
    </svg>
  </button>
  <button class="lb-btn lb-prev" type="button" aria-label="Previous image">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M15 5l-7 7 7 7" />
    </svg>
  </button>
  <button class="lb-btn lb-next" type="button" aria-label="Next image">
    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" stroke-linecap="round" stroke-linejoin="round">
      <path d="M9 5l7 7-7 7" />
    </svg>
  </button>
  <figure class="lb-figure">
    <img class="lb-img" src="" alt="" />
    <figcaption class="lb-cap"></figcaption>
  </figure>
</div>

<style>
  /* ---------- Bento grid ---------- */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 11rem;
    grid-auto-flow: dense;
    gap: 0.85rem;
  }

  /* Gapless patterns: 5 items = featured 2x2 + four 1x1.
     4 items = featured 2x2 + two 1x1 + one wide 2x1. */
  .gallery--n5 .g-tile:first-child,
  .gallery--n4 .g-tile:first-child {
    grid-column: span 2;
    grid-row: span 2;
  }

  .gallery--n4 .g-tile:last-child {
    grid-column: span 2;
  }

  /* ---------- Tile ---------- */
  .g-tile {
    position: relative;
    display: block;
    overflow: hidden;
    padding: 0;
    border: 1px solid var(--line);
    border-radius: 1.1rem;
    background: var(--paper-3);
    box-shadow: 0 20px 40px -28px rgba(16, 27, 49, 0.35);
    cursor: pointer;
    font: inherit;
    color: inherit;
    transition: box-shadow 500ms var(--ease), border-color 500ms var(--ease);
  }

  .g-tile:hover {
    border-color: var(--line-strong);
    box-shadow: 0 30px 60px -30px rgba(16, 27, 49, 0.45);
  }

  .g-tile:focus-visible {
    outline: 2px solid var(--gold);
    outline-offset: 3px;
  }

  .g-tile img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    filter: saturate(0.9) contrast(1.02);
    transition: transform 1200ms var(--ease);
  }

  .g-tile:hover img {
    transform: scale(1.07);
  }

  .g-tile::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(190deg, rgba(16, 27, 49, 0) 45%, rgba(16, 27, 49, 0.52));
    pointer-events: none;
  }

  .g-label {
    position: absolute;
    left: 0.85rem;
    bottom: 0.8rem;
    z-index: 1;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    background: rgba(251, 250, 247, 0.92);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-size: 0.58rem;
    font-weight: 700;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--gold);
  }

  /* Expand affordance */
  .g-zoom {
    position: absolute;
    top: 0.8rem;
    right: 0.8rem;
    z-index: 1;
    width: 2rem;
    height: 2rem;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: rgba(251, 250, 247, 0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    color: var(--ink);
    opacity: 0;
    transform: scale(0.85);
    transition: opacity 400ms var(--ease), transform 400ms var(--ease);
  }

  .g-zoom svg {
    width: 0.85rem;
    height: 0.85rem;
  }

  .g-tile:hover .g-zoom,
  .g-tile:focus-visible .g-zoom {
    opacity: 1;
    transform: scale(1);
  }

  @media (max-width: 760px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 9rem;
      gap: 0.55rem;
    }
    .g-zoom { display: none; }
  }

  /* ---------- Lightbox ---------- */
  .lightbox {
    position: fixed;
    inset: 0;
    z-index: 200;
    display: grid;
    place-items: center;
    padding: clamp(1rem, 5vw, 3.5rem);
    /* Near-opaque, so a full-screen backdrop-filter would cost GPU on
       mobile for no visible gain. */
    background: rgba(16, 27, 49, 0.96);
    opacity: 0;
    transition: opacity 280ms var(--ease);
  }

  .lightbox[hidden] {
    display: none;
  }

  .lightbox.is-open {
    opacity: 1;
  }

  .lb-figure {
    margin: 0;
    max-width: min(1000px, 100%);
    transform: scale(0.965);
    transition: transform 320ms var(--ease);
  }

  .lightbox.is-open .lb-figure {
    transform: scale(1);
  }

  .lb-img {
    display: block;
    max-width: 100%;
    max-height: 78vh;
    margin: 0 auto;
    border-radius: 1rem;
    border: 1px solid var(--line-light);
    box-shadow: 0 50px 90px -40px rgba(0, 0, 0, 0.8);
  }

  .lb-cap {
    margin-top: 1.1rem;
    text-align: center;
    font-size: 0.62rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold-2);
  }

  .lb-btn {
    position: absolute;
    display: grid;
    place-items: center;
    width: 2.9rem;
    height: 2.9rem;
    padding: 0;
    border: 1px solid var(--line-light);
    border-radius: 999px;
    background: rgba(246, 243, 237, 0.08);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    color: var(--paper);
    cursor: pointer;
    transition: background 300ms var(--ease), transform 300ms var(--ease);
  }

  .lb-btn svg {
    width: 1.1rem;
    height: 1.1rem;
  }

  .lb-btn:hover {
    background: rgba(246, 243, 237, 0.18);
  }

  .lb-btn:active {
    transform: scale(0.94);
  }

  .lb-btn:focus-visible {
    outline: 2px solid var(--gold-2);
    outline-offset: 3px;
  }

  .lb-close {
    top: clamp(1rem, 3vw, 2rem);
    right: clamp(1rem, 3vw, 2rem);
  }

  .lb-prev {
    left: clamp(0.6rem, 3vw, 2rem);
    top: 50%;
    transform: translateY(-50%);
  }

  .lb-next {
    right: clamp(0.6rem, 3vw, 2rem);
    top: 50%;
    transform: translateY(-50%);
  }

  .lb-prev:active,
  .lb-next:active {
    transform: translateY(-50%) scale(0.94);
  }

  @media (max-width: 640px) {
    .lb-img { max-height: 68vh; }
    .lb-prev { left: 0.5rem; }
    .lb-next { right: 0.5rem; }
  }
</style>

<script>
  document.querySelectorAll('[data-gallery]').forEach((grid) => {
    const id = grid.getAttribute('data-gallery');
    const lb = document.querySelector(`[data-lightbox="${id}"]`) as HTMLElement | null;
    if (!lb) return;

    const tiles = Array.from(grid.querySelectorAll('.g-tile'));
    const lbImg = lb.querySelector('.lb-img') as HTMLImageElement | null;
    const lbCap = lb.querySelector('.lb-cap') as HTMLElement | null;
    if (!lbImg || !lbCap || tiles.length === 0) return;

    const slides = tiles.map((tile) => {
      const img = tile.querySelector('img');
      const label = tile.querySelector('.g-label');
      return {
        src: img?.getAttribute('src') ?? '',
        alt: img?.getAttribute('alt') ?? '',
        label: label?.textContent?.trim() ?? '',
      };
    });

    let index = 0;
    let lastFocused: HTMLElement | null = null;

    const show = (i: number) => {
      index = (i + slides.length) % slides.length;
      const slide = slides[index];
      lbImg.src = slide.src;
      lbImg.alt = slide.alt;
      lbCap.textContent = slide.label || slide.alt;
    };

    const open = (i: number) => {
      lastFocused = document.activeElement as HTMLElement;
      show(i);
      lb.hidden = false;
      document.body.style.overflow = 'hidden';
      // Force a reflow so the fade has a starting point. rAF would be
      // starved in a background tab, leaving an invisible click-trapping overlay.
      void lb.offsetWidth;
      lb.classList.add('is-open');
      (lb.querySelector('.lb-close') as HTMLElement)?.focus();
    };

    const close = () => {
      lb.classList.remove('is-open');
      document.body.style.overflow = '';
      window.setTimeout(() => {
        lb.hidden = true;
      }, 280);
      lastFocused?.focus();
    };

    tiles.forEach((tile, i) => tile.addEventListener('click', () => open(i)));
    lb.querySelector('.lb-close')?.addEventListener('click', close);
    lb.querySelector('.lb-prev')?.addEventListener('click', () => show(index - 1));
    lb.querySelector('.lb-next')?.addEventListener('click', () => show(index + 1));
    lb.addEventListener('click', (e) => {
      if (e.target === lb) close();
    });

    document.addEventListener('keydown', (e) => {
      if (lb.hidden) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') show(index - 1);
      if (e.key === 'ArrowRight') show(index + 1);
    });
  });
</script>
