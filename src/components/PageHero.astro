---
export interface Props {
  kicker: string;
  title: string;
  titleAccent?: string;
  lede: string;
  showCall?: boolean;
}

const { kicker, title, titleAccent, lede, showCall = true } = Astro.props;
---

<section class="page-hero band">
  <div class="container">
    <div class="page-hero-inner reveal">
      <span class="eyebrow eyebrow--dark">{kicker}</span>
      <h1>{title}{titleAccent && <> <em>{titleAccent}</em></>}</h1>
      <p class="lede">{lede}</p>
      {showCall && (
        <div class="hero-actions">
          <a href="tel:+917760911567" class="btn btn--light">
            Call now: 77609 11567
            <span class="btn-ico">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </span>
          </a>
        </div>
      )}
    </div>
  </div>
</section>

<style>
  .page-hero {
    padding: clamp(9rem, 16vw, 12.5rem) 0 clamp(4.5rem, 8vw, 7rem);
    position: relative;
    overflow: hidden;
  }

  .page-hero-inner {
    max-width: 760px;
  }

  .page-hero h1 {
    font-size: clamp(2.7rem, 5.6vw, 4.4rem);
    margin-bottom: 1.4rem;
  }

  .page-hero h1 em {
    font-style: italic;
    font-weight: 500;
    color: var(--gold-2);
  }

  .page-hero .lede {
    max-width: 56ch;
  }

  .hero-actions {
    margin-top: 2.4rem;
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }
</style>
