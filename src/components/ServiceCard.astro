---
export interface Props {
  title: string;
  description: string;
  imagePath: string;
  link: string;
  imagePosition?: string;
  tag?: string;
}

const { title, description, imagePath, link, imagePosition = 'center', tag } = Astro.props;
---

<a href={link} class="service-card frame">
  <div class="frame-core">
    <div class="card-media">
      <img src={imagePath} alt={title} loading="lazy" style={`object-position: ${imagePosition};`} />
      {tag && <span class="card-tag">{tag}</span>}
    </div>
    <div class="card-body">
      <h3>{title}</h3>
      <p>{description}</p>
      <span class="card-more">
        <span class="more-label">Learn more</span>
        <span class="more-ico">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg>
        </span>
      </span>
    </div>
  </div>
</a>

<style>
  .service-card {
    display: block;
    height: 100%;
    transition: transform 600ms var(--ease-spring), box-shadow 600ms var(--ease);
  }

  .service-card:hover {
    transform: translateY(-6px);
    box-shadow:
      0 1px 0 rgba(255, 255, 255, 0.85) inset,
      0 44px 80px -36px rgba(16, 27, 49, 0.4);
  }

  .service-card:active { transform: scale(0.985); }

  .service-card .frame-core {
    height: 100%;
    display: flex;
    flex-direction: column;
    background: var(--paper-2);
  }

  .card-media {
    position: relative;
    aspect-ratio: 4 / 2.9;
    overflow: hidden;
  }

  .card-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(185deg, rgba(16, 27, 49, 0) 55%, rgba(16, 27, 49, 0.24));
    pointer-events: none;
  }

  .card-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.88) contrast(1.02);
    transition: transform 1100ms var(--ease);
  }

  .service-card:hover .card-media img {
    transform: scale(1.055);
  }

  .card-tag {
    position: absolute;
    top: 0.85rem;
    left: 0.85rem;
    z-index: 1;
    padding: 0.32rem 0.75rem;
    border-radius: 999px;
    background: rgba(251, 250, 247, 0.9);
    backdrop-filter: blur(8px);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--gold);
  }

  .card-body {
    display: flex;
    flex-direction: column;
    flex: 1;
    padding: 1.5rem 1.5rem 1.4rem;
  }

  .card-body h3 {
    font-size: 1.42rem;
    margin-bottom: 0.55rem;
    transition: color 350ms var(--ease);
  }

  .service-card:hover .card-body h3 { color: var(--gold); }

  .card-body p {
    font-size: 0.92rem;
    line-height: 1.65;
    flex: 1;
    margin-bottom: 1.4rem;
  }

  .card-more {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .more-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ink);
    transition: color 350ms var(--ease);
  }

  .more-ico {
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 999px;
    background: rgba(16, 27, 49, 0.06);
    color: var(--ink);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 500ms var(--ease-spring), background 400ms var(--ease), color 400ms var(--ease);
  }

  .more-ico svg { width: 0.85rem; height: 0.85rem; }

  .service-card:hover .more-ico {
    transform: translate(3px, -3px);
    background: var(--ink);
    color: var(--gold-2);
  }

  .service-card:hover .more-label { color: var(--gold); }
</style>
