---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import ServiceCard from '../components/ServiceCard.astro';
import FAQ from '../components/FAQ.astro';
import Popup from '../components/Popup.astro';
import CtaBand from '../components/CtaBand.astro';

const faqs = [
  {
    question: "What areas in Bangalore do you serve?",
    answer: "We provide funeral and ambulance services across all of Bangalore, plus out-of-state ambulance transport. Our main hub is near SAIACS Bible College, Kothanur."
  },
  {
    question: "Do you offer 24/7 ambulance services?",
    answer: "Yes, our ambulance service is available 24/7. We guarantee prompt body pickup and transportation with fully equipped vehicles."
  },
  {
    question: "What is included in the mortuary arrangement?",
    answer: "Our mortuary arrangements include freezer box rentals, professional embalming, dressing and full preservation, so your loved one is kept with dignity."
  },
  {
    question: "Can you help with crematorium bookings?",
    answer: "Yes. We book both traditional and electric crematoriums, arrange the church service and the funeral band set, and handle all the paperwork."
  }
];

const steps = [
  {
    n: '01',
    title: 'Call us, any hour',
    text: 'One phone call is all it takes. We answer straight away, at midnight or midday, and listen to what your family needs.'
  },
  {
    n: '02',
    title: 'We reach you quickly',
    text: 'Our ambulance or hearse van arrives promptly anywhere in Bangalore, with a calm, respectful team.'
  },
  {
    n: '03',
    title: 'Everything arranged',
    text: 'Freezer box, embalming, coffin, flowers, band set, church service, crematorium booking (traditional or electric) and paperwork. We carry it all, so you don’t have to.'
  },
  {
    n: '04',
    title: 'A dignified farewell',
    text: 'Your loved one is honoured with the dignity and reverence they deserve, from the first call to the final rites.'
  }
];

const areas = ['Kothanur', 'Hennur', 'Horamavu', 'Kammanahalli', 'Kalyan Nagar', 'Doddagubbi', 'All of Bangalore', 'Out-of-state'];
---

<Layout title="Home" description="St. Paul's Funeral Undertakers provides dignified 24/7 funeral, ambulance, and mortuary services in Bangalore. Call 77609 11567.">
  <Header />

  <main>
    <!-- ============ HERO ============ -->
    <section class="hero">
      <div class="container">
        <div class="hero-grid">
          <div class="hero-copy reveal">
            <span class="eyebrow">Kothanur, Bangalore · Since day one, 24/7</span>
            <h1>A dignified farewell, <em>arranged with care.</em></h1>
            <p class="lede">When a loved one passes, you shouldn&rsquo;t have to worry about the arrangements. St.&nbsp;Paul&rsquo;s handles all of it, from the ambulance and mortuary to the coffin, church and crematorium, with compassion and at a budget-friendly cost.</p>

            <div class="hero-actions">
              <a href="tel:+917760911567" class="btn btn--gold">
                Call 77609 11567
                <span class="btn-ico">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
                </span>
              </a>
              <a href="#services" class="btn btn--ghost">
                Our services
                <span class="btn-ico">
                  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5v14M6 13l6 6 6-6"/></svg>
                </span>
              </a>
            </div>

            <div class="hero-trust" data-stagger="70">
              <span class="trust-item reveal">Complete arrangements</span>
              <span class="trust-item reveal">Budget-friendly service</span>
              <span class="trust-item reveal">All communities served</span>
            </div>
          </div>

          <div class="hero-visual">
            <div class="frame image-reveal">
              <div class="frame-core hero-media">
                <img src="/Assets/Enhanced/enhanced_wreath_hero.png" alt="White funeral wreath prepared by St Paul's, resting in a church in Bangalore" fetchpriority="high" style="object-position: 50% 60%;" />
              </div>
            </div>

            <div class="hero-float reveal">
              <span class="pulse" aria-hidden="true"></span>
              <div>
                <p class="float-title">We answer right now</p>
                <p class="float-sub">Day or night · 365 days</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- ============ QUIET TRUST STRIP ============ -->
    <section class="strip">
      <div class="container">
        <hr class="rule" />
        <div class="strip-row" data-stagger="80">
          <div class="strip-item reveal">
            <p class="strip-value">24/7</p>
            <p class="strip-label">Always reachable</p>
          </div>
          <div class="strip-item reveal">
            <p class="strip-value">15&ndash;20 <span class="strip-unit">min</span></p>
            <p class="strip-label">Typical response nearby</p>
          </div>
          <div class="strip-item reveal">
            <p class="strip-value">Start to finish</p>
            <p class="strip-label">Pickup to final rites</p>
          </div>
          <div class="strip-item reveal">
            <p class="strip-value">India &amp; abroad</p>
            <p class="strip-label">Repatriation handled</p>
          </div>
        </div>
        <hr class="rule" />
      </div>
    </section>

    <!-- ============ SERVICES ============ -->
    <section class="section" id="services">
      <div class="container">
        <div class="section-header section-header--center reveal">
          <span class="eyebrow">What we take care of</span>
          <h2>Every service, <em class="serif-italic text-gold">under one roof</em></h2>
          <p>From the first phone call to the final farewell: one team, one number, everything arranged.</p>
        </div>

        <div class="services-grid" data-stagger="90">
          <!-- Featured: Ambulance -->
          <a href="/ambulance-service" class="feature-card frame reveal">
            <div class="frame-core feature-core">
              <div class="feature-media">
                <img src="/Assets/Enhanced/enhanced_ambulance.png" alt="St Paul's 24/7 ambulance in Kothanur, Bangalore" loading="lazy" style="object-position: 50% 55%;" />
              </div>
              <div class="feature-body">
                <span class="card-tag-inline">Most requested</span>
                <h3>24/7 Ambulance Service</h3>
                <p>Rapid-response ambulances across Bangalore and out of state. Body pickup and transport with a calm, professional crew, at any hour.</p>
                <span class="card-more">
                  <span class="more-label">Learn more</span>
                  <span class="more-ico">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"><path d="M7 17 17 7M9 7h8v8"/></svg>
                  </span>
                </span>
              </div>
            </div>
          </a>

          <div class="reveal"><ServiceCard
            title="Freezer Box on Rent"
            description="Hygienic preservation at home or hospital, delivered and installed within hours, anywhere in Bangalore."
            imagePath="/Assets/Enhanced/enhanced_freezer_branded.png"
            link="/services/freezer-box"
            imagePosition="50% 50%"
          /></div>

          <div class="reveal"><ServiceCard
            title="Hearse Van Services"
            description="Dignified, air-conditioned hearse vans for safe and respectful final journeys."
            imagePath="/Assets/Enhanced/enhanced_hearse_rear.png"
            link="/services/hearse-van"
            imagePosition="50% 50%"
          /></div>

          <div class="reveal"><ServiceCard
            title="Coffin Boxes"
            description="Premium wooden and standard coffins, prepared with cross, lining and floral dressing."
            imagePath="/Assets/Enhanced/enhanced_wooden_coffin.png"
            link="/services/coffin-box"
            imagePosition="50% 50%"
          /></div>

          <div class="reveal"><ServiceCard
            title="Embalming & Mortuary"
            description="Professional embalming, dressing and complete mortuary arrangements, handled with reverence."
            imagePath="/Assets/imgi_10_st-pauls-funeral-undertaker-kothanur-bangalore-dead-body-freezer-box-on-rent-j5ncmsj2ok.jpg"
            link="/services/embalming"
            imagePosition="50% 25%"
          /></div>

          <div class="reveal"><ServiceCard
            title="International Repatriation"
            description="Complete domestic and international repatriation, including documentation, embassy clearances and airline coordination."
            imagePath="/Assets/international-repatriation.png"
            link="/services/repatriation"
          /></div>
        </div>
      </div>
    </section>

    <!-- ============ FLEET GALLERY ============ -->
    <section class="section bg-paper2 gallery-section">
      <div class="container">
        <div class="section-header section-header--center reveal">
          <span class="eyebrow">Our fleet &amp; facilities</span>
          <h2>Real vehicles, <em class="serif-italic text-gold">genuine care</em></h2>
          <p>Every ambulance, hearse, freezer box and coffin you see here is ours, maintained with respect and ready around the clock.</p>
        </div>

        <div class="gallery-bento" data-stagger="70">
          <figure class="g-item g-a reveal">
            <img src="/Assets/hearse-qualis.jpg" alt="St Paul's branded hearse vehicle, Bangalore" loading="lazy" />
            <figcaption>Hearse fleet</figcaption>
          </figure>
          <figure class="g-item reveal">
            <img src="/Assets/coffin-black-open.jpg" alt="Black coffin with white satin lining and gold cross" loading="lazy" />
            <figcaption>Coffins</figcaption>
          </figure>
          <figure class="g-item reveal">
            <img src="/Assets/freezer-glass-dome.jpg" alt="Stainless steel and glass mortuary freezer box" loading="lazy" style="object-position: 50% 40%;" />
            <figcaption>Freezer boxes</figcaption>
          </figure>
          <figure class="g-item reveal">
            <img src="/Assets/coffin-golden.jpg" alt="Golden wooden coffin with cross" loading="lazy" style="object-position: 50% 55%;" />
            <figcaption>Coffins</figcaption>
          </figure>
          <figure class="g-item reveal">
            <img src="/Assets/ambulance-stretcher.jpg" alt="Ambulance interior with stretcher, St Paul's Bangalore" loading="lazy" />
            <figcaption>Equipped interiors</figcaption>
          </figure>
          <figure class="g-item g-wide reveal">
            <img src="/Assets/hearse-interior.jpg" alt="Hearse van interior with seating and coffin platform" loading="lazy" style="object-position: 50% 60%;" />
            <figcaption>Hearse interior</figcaption>
          </figure>
          <figure class="g-item reveal">
            <img src="/Assets/coffin-wood-cross.jpg" alt="Polished wooden coffin with gold cross" loading="lazy" />
            <figcaption>Coffins</figcaption>
          </figure>
          <figure class="g-item reveal">
            <img src="/Assets/ambulance-eeco-rear.jpg" alt="St Paul's white ambulance with branding, Bangalore" loading="lazy" style="object-position: 50% 45%;" />
            <figcaption>Ambulances</figcaption>
          </figure>
        </div>
      </div>
    </section>

    <!-- ============ VERSE ============ -->
    <section class="verse-section section--tight">
      <div class="container">
        <blockquote class="verse reveal">
          <p class="verse-text">&ldquo;Precious in the sight of the Lord is the death of his faithful&nbsp;servants.&rdquo;</p>
          <cite>Psalm 116:15</cite>
        </blockquote>
      </div>
    </section>

    <!-- ============ HOW WE HELP ============ -->
    <section class="section band process-band">
      <div class="container">
        <div class="section-header reveal">
          <span class="eyebrow eyebrow--dark">In your hardest hour</span>
          <h2>You make one call.<br /><em class="process-accent">We carry the rest.</em></h2>
        </div>

        <div class="process-grid" data-stagger="110">
          {steps.map(step => (
            <div class="process-step reveal">
              <span class="step-n">{step.n}</span>
              <h3>{step.title}</h3>
              <p>{step.text}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- ============ AREAS + VISIT ============ -->
    <section class="section">
      <div class="container">
        <div class="areas-grid">
          <div class="reveal">
            <span class="eyebrow">Where we serve</span>
            <h2>Rooted in Kothanur, <em class="serif-italic text-gold">serving every family</em></h2>
            <p class="lede" style="margin-top: 1.1rem;">Our hub near SAIACS Bible College lets us reach the surrounding neighbourhoods in 15 to 20 minutes, and our vans travel across Karnataka and beyond.</p>

            <div class="area-chips" data-stagger="55">
              {areas.map(area => <span class="area-chip reveal">{area}</span>)}
            </div>
          </div>

          <aside class="visit-card frame reveal">
            <div class="frame-core visit-core">
              <span class="eyebrow">Visit us</span>
              <p class="visit-address">Aathma Vidhya Nagar,<br />Doddagubbi Main Road,<br />Bangalore 560077</p>
              <p class="visit-landmark">Landmark: near SAIACS Bible College, Kothanur</p>
              <div class="visit-tels">
                <a class="tel-link" href="tel:+917760911567">77609 11567</a>
                <span class="tel-sep">/</span>
                <a class="tel-link" href="tel:+917996794943">79967 94943</a>
              </div>
            </div>
          </aside>
        </div>
      </div>
    </section>

    <!-- ============ FAQ ============ -->
    <section class="section bg-paper2 faq-section">
      <div class="container">
        <FAQ faqs={faqs} />
      </div>
    </section>

    <CtaBand />
  </main>

  <Footer />

  <Popup
    id="condolence"
    variant="gentle"
    kicker="You are not alone"
    heading="If you have just lost someone,"
    emphasis="we are here."
    body="Take your time. When you are ready, one call is all it takes. We will explain what happens next and quietly take care of every arrangement, at any hour."
    ctaLabel="Call 77609 11567"
    ctaHref="tel:+917760911567"
    dismissLabel="I'm only looking for now"
    delay={2600}
    remember="session"
  />
</Layout>

<style>
  /* ---------- Hero ---------- */
  .hero {
    padding: 13rem 0 clamp(3rem, 5vw, 4.5rem);
    position: relative;
    overflow: hidden;
  }
  @media (min-width: 768px) {
    .hero {
      padding-top: clamp(9.5rem, 15vw, 11.5rem);
    }
  }

  .hero::before {
    content: '';
    position: absolute;
    top: -20%;
    right: -12%;
    width: 640px;
    height: 640px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(194, 161, 99, 0.16), transparent 65%);
    pointer-events: none;
  }

  .hero::after {
    content: '';
    position: absolute;
    bottom: -30%;
    left: -14%;
    width: 560px;
    height: 560px;
    border-radius: 50%;
    background: radial-gradient(circle, rgba(38, 62, 110, 0.1), transparent 65%);
    pointer-events: none;
  }

  .hero-grid {
    position: relative;
    z-index: 1;
    display: grid;
    grid-template-columns: 1.08fr 0.92fr;
    gap: clamp(2.5rem, 6vw, 5.5rem);
    align-items: center;
  }

  .hero-copy h1 {
    margin-bottom: 1.5rem;
  }

  .hero-copy h1 em {
    font-style: italic;
    font-weight: 500;
    color: var(--gold);
  }

  .hero-actions {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-top: 2.4rem;
  }

  .hero-trust {
    display: flex;
    align-items: center;
    gap: 1.1rem;
    flex-wrap: wrap;
    margin-top: 2.6rem;
  }

  .trust-item {
    position: relative;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.02em;
    color: var(--muted);
    padding-left: 1.1rem;
  }

  .trust-item::before {
    content: '';
    position: absolute;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    width: 5px;
    height: 5px;
    border-radius: 50%;
    background: var(--gold-2);
  }

  /* Hero visual */
  .hero-visual {
    position: relative;
  }

  .hero-media {
    aspect-ratio: 4 / 4.6;
  }

  .hero-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: 50% 68%;
    filter: saturate(0.9) contrast(1.02);
  }

  .hero-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(200deg, rgba(16, 27, 49, 0.18), transparent 45%);
    pointer-events: none;
  }

  .hero-float {
    position: absolute;
    left: clamp(-1.2rem, -2vw, -2rem);
    bottom: 2.2rem;
    display: flex;
    align-items: center;
    gap: 0.9rem;
    padding: 1rem 1.5rem 1rem 1.15rem;
    border-radius: 1.3rem;
    background: rgba(251, 250, 247, 0.92);
    backdrop-filter: blur(14px);
    -webkit-backdrop-filter: blur(14px);
    border: 1px solid rgba(16, 27, 49, 0.08);
    box-shadow: 0 1px 0 rgba(255,255,255,0.8) inset, 0 30px 55px -22px rgba(16, 27, 49, 0.45);
  }

  .pulse {
    position: relative;
    width: 0.7rem;
    height: 0.7rem;
    border-radius: 50%;
    background: var(--gold);
    flex: none;
  }

  .pulse::after {
    content: '';
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 1.5px solid rgba(160, 127, 60, 0.5);
    animation: pulse-ring 2.4s var(--ease) infinite;
  }

  @keyframes pulse-ring {
    0% { transform: scale(0.6); opacity: 1; }
    70%, 100% { transform: scale(1.35); opacity: 0; }
  }

  .float-title {
    font-family: var(--font-display);
    font-size: 1.12rem;
    font-weight: 600;
    color: var(--ink);
    line-height: 1.2;
  }

  .float-sub {
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted);
    margin-top: 0.15rem;
  }

  /* ---------- Trust strip ---------- */
  .strip { padding: clamp(1.5rem, 3vw, 2.5rem) 0; }

  .strip-row {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    padding: clamp(1.8rem, 3.5vw, 2.8rem) clamp(0.5rem, 2vw, 2rem);
    text-align: center;
  }

  .strip-value {
    font-family: var(--font-display);
    font-size: clamp(1.7rem, 3vw, 2.3rem);
    font-weight: 600;
    color: var(--ink);
    line-height: 1.1;
  }

  .strip-unit { font-size: 0.6em; color: var(--gold); }

  .strip-label {
    margin-top: 0.4rem;
    font-size: 0.74rem;
    font-weight: 600;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--muted-2);
  }

  /* ---------- Services grid ---------- */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.4rem;
  }

  .feature-card {
    grid-column: span 2;
    display: block;
    transition: transform 600ms var(--ease-spring), box-shadow 600ms var(--ease);
  }

  .feature-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 1px 0 rgba(255,255,255,0.85) inset, 0 44px 80px -36px rgba(16, 27, 49, 0.4);
  }

  .feature-card:active { transform: scale(0.985); }

  .feature-core {
    display: grid;
    grid-template-columns: 1.05fr 1fr;
    height: 100%;
    background: var(--ink);
  }

  .feature-media {
    position: relative;
    overflow: hidden;
    min-height: 300px;
  }

  .feature-media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.9);
    transition: transform 1100ms var(--ease);
  }

  .feature-card:hover .feature-media img { transform: scale(1.055); }

  .feature-media::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(90deg, transparent 55%, rgba(16, 27, 49, 0.55));
  }

  .feature-body {
    padding: clamp(1.6rem, 3vw, 2.4rem);
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .card-tag-inline {
    display: inline-block;
    width: max-content;
    padding: 0.32rem 0.75rem;
    border-radius: 999px;
    background: rgba(194, 161, 99, 0.16);
    border: 1px solid rgba(194, 161, 99, 0.3);
    color: var(--gold-2);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    margin-bottom: 1.1rem;
  }

  .feature-body h3 {
    color: #f4f1ea;
    font-size: clamp(1.6rem, 2.6vw, 2rem);
    margin-bottom: 0.7rem;
  }

  .feature-body p {
    color: rgba(238, 240, 238, 0.66);
    font-size: 0.95rem;
    margin-bottom: 1.6rem;
  }

  .feature-body .more-label { color: rgba(244, 241, 234, 0.85); }

  .feature-body .card-more {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
  }

  .feature-body .more-label {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .feature-body .more-ico {
    width: 1.9rem;
    height: 1.9rem;
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.1);
    color: var(--gold-2);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: transform 500ms var(--ease-spring), background 400ms var(--ease);
  }

  .feature-body .more-ico svg { width: 0.85rem; height: 0.85rem; }

  .feature-card:hover .more-ico {
    transform: translate(3px, -3px);
    background: rgba(255, 255, 255, 0.18);
  }

  /* ---------- Fleet gallery ---------- */
  .gallery-bento {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    grid-auto-rows: 12rem;
    gap: 0.9rem;
  }

  .g-item {
    position: relative;
    overflow: hidden;
    border-radius: 1.1rem;
    border: 1px solid var(--line);
    box-shadow: 0 20px 40px -28px rgba(16, 27, 49, 0.35);
    margin: 0;
  }

  .g-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: saturate(0.9) contrast(1.02);
    transition: transform 1200ms var(--ease);
  }

  .g-item:hover img { transform: scale(1.06); }

  .g-item::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(190deg, rgba(16, 27, 49, 0) 45%, rgba(16, 27, 49, 0.5));
    pointer-events: none;
  }

  .g-item figcaption {
    position: absolute;
    left: 0.9rem;
    bottom: 0.8rem;
    z-index: 1;
    padding: 0.3rem 0.7rem;
    border-radius: 999px;
    background: rgba(251, 250, 247, 0.9);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    font-size: 0.6rem;
    font-weight: 700;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--gold);
  }

