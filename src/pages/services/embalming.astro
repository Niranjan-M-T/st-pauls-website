---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import PageHero from '../../components/PageHero.astro';
import CtaBand from '../../components/CtaBand.astro';
import Gallery from '../../components/Gallery.astro';

const gallery = [
  { src: '/Assets/imgi_3_st-pauls-funeral-undertaker-kothanur-bangalore-dead-body-freezer-box-on-rent-27zuxkkd1e.jpg', alt: 'White funeral wreath of roses and chrysanthemums prepared by St Paul\'s', label: 'Flower arrangement', position: '50% 60%' },
  { src: '/Assets/coffin-black-open.jpg', alt: 'Coffin dressed with white satin lining and gold cross', label: 'Dressing & lining' },
  { src: '/Assets/imgi_10_st-pauls-funeral-undertaker-kothanur-bangalore-dead-body-freezer-box-on-rent-j5ncmsj2ok.jpg', alt: 'Casket prepared with cross and floral wreath', label: 'Final preparation', position: '50% 30%' },
  { src: '/Assets/freezer-glass.jpg', alt: 'Mortuary viewing casket with glass panels and polished trim', label: 'Mortuary casket' },
  { src: '/Assets/coffin-black-lining.jpg', alt: 'Coffin interior lined with white satin ready for presentation', label: 'Satin interior' },
];
---

<Layout title="Mortuary & Embalming Services Bangalore" description="Professional mortuary and embalming services in Bangalore. Complete care, dressing and preservation by St. Paul's Funeral Undertakers.">
  <Header />

  <main>
    <PageHero
      kicker="Handled with reverence"
      title="Embalming & mortuary,"
      titleAccent="with professional care."
      lede="Certified embalming, washing, dressing and casket preparation — carried out gently, according to your family's religious and cultural traditions."
    />

    <section class="section">
      <div class="container split">
        <div class="split-copy reveal">
          <span class="eyebrow">Care &amp; preservation</span>
          <h2>Peaceful, natural, <em class="serif-italic text-gold">and unhurried</em></h2>
          <p>Embalming is essential for long-distance transportation or when the funeral must wait for loved ones to arrive. Our certified professionals use modern techniques so the deceased looks peaceful and natural.</p>
          <p>We also handle washing, dressing and casket preparation according to the family&rsquo;s religious or cultural traditions — every detail treated as sacred.</p>
          <ul class="check-list">
            <li><span class="tick"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6.5 4.5 9 10 3"/></svg></span> Certified, experienced embalmers</li>
            <li><span class="tick"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6.5 4.5 9 10 3"/></svg></span> Embalming certificates for travel &amp; repatriation</li>
            <li><span class="tick"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6.5 4.5 9 10 3"/></svg></span> Washing, dressing and presentation</li>
            <li><span class="tick"><svg viewBox="0 0 12 12" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 6.5 4.5 9 10 3"/></svg></span> All faiths and traditions respected</li>
          </ul>
        </div>
        <div class="split-media">
          <div class="frame image-reveal">
            <div class="frame-core">
              <img src="/Assets/imgi_10_st-pauls-funeral-undertaker-kothanur-bangalore-dead-body-freezer-box-on-rent-j5ncmsj2ok.jpg" alt="Casket prepared with cross and wreath — mortuary services Bangalore" style="object-position: 50% 30%;" />
            </div>
          </div>
        </div>
      </div>
    </section>

    <Gallery
      id="mortuary"
      kicker="Preparation & presentation"
      heading="Presented with"
      emphasis="quiet dignity"
      note="Tap any photograph to view it larger. Dressing, casket preparation and floral work, all handled in-house."
      items={gallery}
    />

    <CtaBand
      accent="Every tradition honoured."
      heading="Every tradition honoured. Every detail handled."
      note="Call us — our team will explain the process gently and take care of everything."
    />
  </main>

  <Footer />
</Layout>
